// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Preinscription {
  id                      String   @id @default(cuid())
  
  // Informations personnelles
  nom                     String
  prenom                  String
  email                   String   @unique
  telephone               String
  dateNaissance           String   @map("date_naissance")
  lieuNaissance           String?  @map("lieu_naissance")
  sexe                    String?
  nationalite             String?  @default("Burkinabe")
  adresse                 String?
  
  // Piece d'identite
  typePiece               String   @map("type_piece")
  numeroPiece             String   @map("numero_piece")
  dateDelivrancePiece     String?  @map("date_delivrance_piece")
  dateExpirationPiece     String?  @map("date_expiration_piece")
  fichierPieceUrl         String?  @map("fichier_piece_url")
  
  // Informations universitaires
  universite              String
  filiere                 String
  niveauEtudes            String   @map("niveau_etudes")
  matricule               String?
  attestationUrl          String?  @map("attestation_url")
  photoUrl                String?  @map("photo_url")
  
  // Contact d'urgence
  contactUrgenceNom       String?  @map("contact_urgence_nom")
  contactUrgenceTelephone String?  @map("contact_urgence_telephone")
  contactUrgenceLien      String?  @map("contact_urgence_lien")
  
  // Ayants-droit
  ajouterAyantsDroit      Boolean  @default(false) @map("ajouter_ayants_droit")
  ayantsDroit             Json?    @map("ayants_droit")
  
  // Conditions
  accepteConditions       Boolean  @default(false) @map("accepte_conditions")
  
  // Statut de la préinscription
  status                  String   @default("pending")
  
  // Paiement (géré via WhatsApp)
  paymentStatus           String   @default("unpaid") @map("payment_status")
  paymentMethod           String?  @map("payment_method")
  paymentReference        String?  @map("payment_reference")
  paymentPhone            String?  @map("payment_phone")
  paymentDate             DateTime? @map("payment_date")
  
  // Dates
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("preinscriptions")
}
